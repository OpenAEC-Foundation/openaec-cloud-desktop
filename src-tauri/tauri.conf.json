{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAEC Cloud",
  "version": "0.1.0",
  "identifier": "com.openaec.cloud",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "title": "OpenAEC Cloud", "width": 1000, "height": 680, "minWidth": 760, "minHeight": 520 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.png"],
    "resources": ["WebView2Loader.dll"],
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper", "silent": true }
    }
  }
}
